# Gateway — entry point (port 8000)
PORT=8000
APP_ENV=development
LOG_LEVEL=debug

# JWT verification (RS256 public key — file path or inline PEM)
JWT_PUBLIC_KEY_PATH=../keys/jwt_public.pem
JWT_PUBLIC_KEY=

# Internal service URLs (local)
USER_SERVICE_URL=http://localhost:4001
BACKEND_URL=http://localhost:4002
ADMIN_URL=http://localhost:4003

# Redis — rate limiting, IP blocklist cache
REDIS_URL=redis://localhost:6379

# CORS — comma-separated origins
CORS_ORIGINS=http://localhost:3000

# Proxy timeouts (seconds)
PROXY_CONNECT_TIMEOUT_SECONDS=5
PROXY_READ_TIMEOUT_SECONDS=30
PROXY_WRITE_TIMEOUT_SECONDS=30

# Observability (optional)
SENTRY_DSN=
