# Admin — dashboard API (port 4003)
PORT=4003
APP_ENV=development
LOG_LEVEL=debug

# PostgreSQL
DATABASE_URL=postgresql+asyncpg://chicaboo:chicaboo@localhost:5433/chicaboo

# Redis — admin session cache
REDIS_URL=redis://localhost:6379

# Admin JWT (separate from customer JWT — HS256 or RS256)
ADMIN_JWT_SECRET=change-me-local-dev-admin-secret-min-32-chars
ADMIN_JWT_TTL_SECONDS=28800

# MFA issuer label (TOTP)
ADMIN_MFA_ISSUER=ChicABoo Admin

# Observability (optional)
SENTRY_DSN=
