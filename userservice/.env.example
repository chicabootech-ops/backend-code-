# UserService — auth & identity (port 4001)
PORT=4001
APP_ENV=development
LOG_LEVEL=debug

# PostgreSQL (async SQLAlchemy — use pooler 6543 + ?pgbouncer=true in prod)
DATABASE_URL=postgresql+asyncpg://chicaboo:chicaboo@localhost:5433/chicaboo

# Upstash Redis / local Redis
REDIS_URL=redis://localhost:6379

# JWT RS256
JWT_PRIVATE_KEY_PATH=../keys/jwt_private.pem
JWT_PRIVATE_KEY=
JWT_PUBLIC_KEY_PATH=../keys/jwt_public.pem
JWT_PUBLIC_KEY=
JWT_ACCESS_TTL_SECONDS=900
JWT_REFRESH_TTL_SECONDS=604800
JWT_REFRESH_SECRET=change-me-local-dev-refresh-secret-min-32-chars

# OTP & password reset TTLs
OTP_TTL_SECONDS=600
PASSWORD_RESET_TTL_SECONDS=3600

# Resend (primary) or SMTP fallback
RESEND_API_KEY=
EMAIL_FROM=noreply@chicaboo.com
SMTP_HOST=
SMTP_USER=
SMTP_PASS=

# Account lockout
MAX_FAILED_LOGIN_ATTEMPTS=5
ACCOUNT_LOCKOUT_MINUTES=30

# Rate limits (requests per window — see RateLimitService)
RATE_LIMIT_LOGIN=10
RATE_LIMIT_REGISTER=5
RATE_LIMIT_VERIFY_EMAIL=10
RATE_LIMIT_FORGOT_PASSWORD=5
RATE_LIMIT_RESET_PASSWORD=10
RATE_LIMIT_REFRESH=30

SENTRY_DSN=

# Cloudflare R2 (avatar storage)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=chicaboo-assets
R2_ENDPOINT_URL=
AVATAR_MAX_SIZE_BYTES=5242880
AVATAR_UPLOAD_URL_TTL_SECONDS=900
AVATAR_GET_URL_TTL_SECONDS=3600
