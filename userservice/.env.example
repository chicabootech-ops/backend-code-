# UserService — auth & identity (port 4001)
PORT=4001
APP_ENV=development
LOG_LEVEL=debug

# PostgreSQL (async SQLAlchemy)
DATABASE_URL=postgresql+asyncpg://chicaboo:chicaboo@localhost:5433/chicaboo

# Redis — refresh tokens, OTP cache, rate limits, token blacklist
REDIS_URL=redis://localhost:6379

# JWT RS256 — private key signs tokens; public key shared with Gateway
JWT_PRIVATE_KEY_PATH=../keys/jwt_private.pem
JWT_PRIVATE_KEY=
JWT_PUBLIC_KEY_PATH=../keys/jwt_public.pem
JWT_PUBLIC_KEY=

# Refresh token HMAC secret (additional layer for cookie signing)
JWT_REFRESH_SECRET=change-me-local-dev-refresh-secret-min-32-chars

# Email — Resend (production) or SMTP (local fallback)
RESEND_API_KEY=
EMAIL_FROM=noreply@chicaboo.com
SMTP_HOST=
SMTP_USER=
SMTP_PASS=

# Token TTLs (seconds)
JWT_ACCESS_TTL_SECONDS=900
JWT_REFRESH_TTL_SECONDS=604800

# Account lockout
MAX_FAILED_LOGIN_ATTEMPTS=5
ACCOUNT_LOCKOUT_MINUTES=30

# Observability (optional)
SENTRY_DSN=
