# Shared infrastructure — used by docker-compose and local development
# Copy to .env at repo root: cp .env.example .env

POSTGRES_USER=chicaboo
POSTGRES_PASSWORD=chicaboo
POSTGRES_DB=chicaboo
POSTGRES_HOST=localhost
POSTGRES_PORT=5433

REDIS_HOST=localhost
REDIS_PORT=6379

# Async SQLAlchemy URL (local Postgres via docker compose)
DATABASE_URL=postgresql+asyncpg://chicaboo:chicaboo@localhost:5433/chicaboo

# psycopg2 URL for database/migrate.py
DATABASE_MIGRATE_URL=postgresql://chicaboo:chicaboo@localhost:5433/chicaboo

REDIS_URL=redis://localhost:6379

# Frontend origin (Gateway CORS)
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# App environment
APP_ENV=development
LOG_LEVEL=debug
