# Chic A Boo unified API — copy to .env and fill values
# Local: cp .env.example .env
# Render: paste into Environment

PORT=8000
APP_ENV=development
LOG_LEVEL=info

# Neon / Postgres (asyncpg). Keep ?ssl=require for Neon.
DATABASE_URL=postgresql+asyncpg://chicaboo:chicaboo@localhost:5433/chicaboo

REDIS_URL=redis://localhost:6379

# Comma-separated frontend origins
CORS_ORIGINS=http://localhost:3000,http://localhost:3001,https://www.chicaboo.co,https://chicaboo.co

# Public storefront URL (reset links + email branding)
SITE_URL=https://www.chicaboo.co

# Customer JWT (RS256)
# Render: paste full PEM into JWT_PRIVATE_KEY + JWT_PUBLIC_KEY (multiline OK).
# Local: leave those empty and use file paths below (openssl → keys/*.pem).
JWT_PRIVATE_KEY=
JWT_PUBLIC_KEY=
JWT_PRIVATE_KEY_PATH=keys/jwt_private.pem
JWT_PUBLIC_KEY_PATH=keys/jwt_public.pem
JWT_REFRESH_SECRET=change-me-local-dev-refresh-secret-min-32-chars
JWT_ACCESS_TTL_SECONDS=900
JWT_REFRESH_TTL_SECONDS=604800

OTP_TTL_SECONDS=600
PASSWORD_RESET_TTL_SECONDS=3600

# Email — Resend primary (verify chicaboo.co domain in Resend dashboard)
RESEND_API_KEY=
EMAIL_FROM=noreply@chicaboo.co
EMAIL_FROM_NAME=Chic A Boo
EMAIL_REPLY_TO=support@chicaboo.co
EMAIL_ADMIN=admin@chicaboo.co
# SMTP fallback (Gmail app password or other SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=

# Message Central VerifyNow SMS OTP
# https://www.messagecentral.com — Customer ID + login email/password
MESSAGE_CENTRAL_CUSTOMER_ID=
MESSAGE_CENTRAL_EMAIL=
MESSAGE_CENTRAL_PASSWORD=
MESSAGE_CENTRAL_COUNTRY_CODE=91
MESSAGE_CENTRAL_OTP_LENGTH=6

MAX_FAILED_LOGIN_ATTEMPTS=5
ACCOUNT_LOCKOUT_MINUTES=30
RATE_LIMIT_LOGIN=10
RATE_LIMIT_REGISTER=5
RATE_LIMIT_VERIFY_EMAIL=10
RATE_LIMIT_FORGOT_PASSWORD=5
RATE_LIMIT_RESET_PASSWORD=10
RATE_LIMIT_REFRESH=30
RATE_LIMIT_PHONE_OTP=5
RATE_LIMIT_RESEND_VERIFICATION=5

# Admin JWT (HS256)
ADMIN_JWT_SECRET=change-me-local-dev-admin-secret-min-32-chars
ADMIN_JWT_TTL_SECONDS=28800
ADMIN_MFA_ISSUER=Chic A Boo Admin

# Cloudflare R2
R2_BUCKET=chicaboo-assets
R2_BUCKET_NAME=chicaboo-assets
R2_ACCOUNT_ID=
R2_ACCESS_KEY=
R2_SECRET_KEY=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_ENDPOINT_URL=
R2_PUBLIC_BASE_URL=
AVATAR_MAX_SIZE_BYTES=5242880
AVATAR_UPLOAD_URL_TTL_SECONDS=900
AVATAR_GET_URL_TTL_SECONDS=3600

# Razorpay
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

SENTRY_DSN=
