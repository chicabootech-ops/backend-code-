# Backend — e-commerce core (port 4002)
PORT=4002
APP_ENV=development
LOG_LEVEL=debug

# PostgreSQL
DATABASE_URL=postgresql+asyncpg://chicaboo:chicaboo@localhost:5433/chicaboo

# Redis — cart cache, product cache, BullMQ queues
REDIS_URL=redis://localhost:6379

# Cloudflare R2 (S3-compatible)
R2_BUCKET=chicaboo-assets
R2_ACCOUNT_ID=
R2_ACCESS_KEY=
R2_SECRET_KEY=
R2_ENDPOINT_URL=
R2_PUBLIC_BASE_URL=

# Razorpay
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# Internal UserService (token validation, user lookup)
USER_SERVICE_URL=http://localhost:4001

# Observability (optional)
SENTRY_DSN=
